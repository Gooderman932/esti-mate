# Copy to backend/.env and fill in the values below.

# --- Required ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=esti_mate

# --- Stripe (subscription billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Either set STRIPE_PRICE_ID (legacy single-tier) or both _PRO and _ENTERPRISE.
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# Public URL used by Stripe checkout to redirect back to your app.
APP_URL=http://localhost:3000

# --- Google Play (Android subscriptions) ---
GOOGLE_PLAY_PACKAGE_NAME=com.poordudeholdings.estimatemobile
# Optional service-account JSON (single line) for verifying purchases via the
# Play Developer API. Leave blank to skip server-side verification.
GOOGLE_SERVICE_ACCOUNT_JSON=
